{
  "name": "a2ui-vue",
  "version": "0.1.1",
  "description": "Vue 3 renderer for Google A2UI protocol with validation and human-in-the-loop helpers",
  "type": "module",
  "main": "./dist/a2ui-vue.umd.cjs",
  "module": "./dist/a2ui-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/a2ui-vue.js",
      "require": "./dist/a2ui-vue.umd.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "tailwindcss": "^3.4.0 || ^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "keywords": [
    "a2ui",
    "vue",
    "vue3",
    "agent-ui",
    "generative-ui",
    "human-in-the-loop",
    "ag-ui",
    "tailwindcss",
    "ai-agent",
    "langgraph"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vkfolio/a2ui-vue"
  }
}
